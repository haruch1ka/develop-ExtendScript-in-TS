    "module": "esnext",
    "strict": true,
    "noLib": true,
    "types": ["types-for-adobe/InDesign/2021"],
    "rootDir": "./src",
    "outDir": "./compiled",
    "emitBOM": true
  },
  "include": ["./src/**/*.ts", "./src/types/**/*.d.ts"],
